---
import {getLegacyGuideStepRedirects} from '#lib/legacy-guide-redirects'

export function getStaticPaths() {
	return getLegacyGuideStepRedirects().map(({from, to, status}) => {
		const [legacy_guide, ...legacy_step] = from
			.replace(/^\//, '')
			.split('/')

		return {
			params: {
				legacy_guide,
				legacy_step: legacy_step.join('/'),
			},
			props: {to, status},
		}
	})
}

const {to, status} = Astro.props

return Astro.redirect(to, status)
---

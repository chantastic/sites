---
import Layout from '#layouts/Layout.astro'
import PostMeta from '#components/header-post-meta.astro'
import * as LESSONS from '#content/lessons/_lessons'
import Prose from '#components/prose.astro'
import {renderEntry} from '#lib/content-entry'

export async function getStaticPaths() {
	const lessons = await LESSONS.getCollection()

	return lessons.map((entry) => ({
		params: {
			lesson_slug: LESSONS.lessonSlug(entry),
		},
		props: {entry},
	}))
}

interface Props {
	entry: LESSONS.CollectionEntry
}

const {entry} = Astro.props
const {Content} = await renderEntry(entry)

const previousEntry = await LESSONS.getEntryByRelativeOrder(entry, -1)
const nextEntry = await LESSONS.getEntryByRelativeOrder(entry, 1)
const collection_name = LESSONS.collectionName(entry)
const course_name = LESSONS.courseName(entry)
const hasCourse = Boolean(course_name)
---

<Layout>
	<Prose>
		<small>
			⇠ <a href="/">chan.dev</a>/{' '}
			<a href={`/${LESSONS.path()}`}>lessons</a>/{' '}
			<a href={`/${LESSONS.collectionPath(collection_name)}`}>
				{collection_name}
			</a>
			{hasCourse && (
				<>
					/{' '}
					<a href={`/${LESSONS.coursePath(LESSONS.courseKey(entry))}`}>
						{course_name}
					</a>
				</>
			)}
		</small>
		<main class="mt-4">
			<h1 class="tracking-tight">{entry.data.title}</h1>
			<Content />
			{hasCourse && (
				<nav class="flex justify-between">
					{previousEntry && (
						<a href={`/${LESSONS.lessonPath(previousEntry)}`}>
							← {previousEntry.data.title}
						</a>
					)}
					{nextEntry && (
						<a href={`/${LESSONS.lessonPath(nextEntry)}`}>
							{nextEntry.data.title} →
						</a>
					)}
				</nav>
			)}
		</main>
	</Prose>
	<PostMeta
		title={String(entry.data.title)}
		path={LESSONS.lessonPath(entry)}
		slot="page-meta"
	/>
</Layout>

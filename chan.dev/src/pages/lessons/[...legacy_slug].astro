---
import {getLegacyLessonRedirects} from '#lib/legacy-lesson-redirects'

export function getStaticPaths() {
	return getLegacyLessonRedirects().map(({from, to, status}) => ({
		params: {
			legacy_slug: from.replace(/^\/lessons\//, ''),
		},
		props: {to, status},
	}))
}

const {to, status} = Astro.props

return Astro.redirect(to, status)
---

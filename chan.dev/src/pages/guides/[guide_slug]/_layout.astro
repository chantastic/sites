---
import ParentLayout from '#layouts/Layout.astro'
import Prose from '#components/prose.astro'
import * as GUIDE_STEPS from '#content/guide_steps/_guide_steps'

let {params} = Astro

let entries = await GUIDE_STEPS.getEntriesForGuide(
	String(params.guide_slug)
)
---

<ParentLayout>
	<Prose as="div" class="grid grid-cols-3 gap-8">
		<main class="col-span-2">
			<slot />
		</main>
		<nav>
			<ol>
				{entries.map((entry) => (
					<li
						class:list={[
							{
								'bg-white rounded':
									GUIDE_STEPS.isCurrentGuideStep(
										entry,
										params.guide_step_slug
									),
							},
						]}
					>
						<a
							href={GUIDE_STEPS.guideStepPath(entry)}
							class:list={[
								{
									'text-slate-600':
										GUIDE_STEPS.isCurrentGuideStep(
											entry,
											params.guide_step_slug
										),
								},
							]}
						>
							{entry.data.title}
							{entry.data.status === 'draft' && <span> [draft]</span>}
						</a>
					</li>
				))}
			</ol>
		</nav>
	</Prose>
</ParentLayout>
